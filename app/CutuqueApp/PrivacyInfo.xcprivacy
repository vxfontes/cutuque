<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- O app não rastreia o usuário nem envia dados a domínios de tracking. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Nenhum dado do usuário é coletado pelo desenvolvedor. O app fala apenas
	     com o hub do próprio usuário (rede privada). Ao APNs vão só metadados
	     de sessão (ex.: "sessão X concluiu"), sem vínculo com a identidade. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- APIs de "razão obrigatória" efetivamente usadas pelo app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults: preferências e configuração do próprio app. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<!-- ProcessInfo.systemUptime: relógio monotônico para medir tempo
			     decorrido entre eventos (ForegroundReporter). -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
