# Template do hub.env de produção (Fase 5 — deploy no ZimaOS/192.0.2.10).
#
# Copie para ./config/hub.env (mesmo diretório) e preencha os valores reais.
# hub.env é gitignored (ver .gitignore, /config/) — NUNCA versionar o real.

CUTUQUE_ENV=prod

# IP Tailscale do próprio hub. Em prod o hub escuta SÓ nessa interface (nunca
# 0.0.0.0) — ver docs/02-arquitetura.md e review/security.md.
CUTUQUE_BIND=192.0.2.10

# Bearer token dos devices (app iOS/watchOS) e de qualquer chamada de comando
# (/sessions, /devices, etc). Gere um forte, ex.:
#   openssl rand -hex 32
# Obrigatório em prod — o hub recusa subir sem ele (fail-fast, SEC-001).
CUTUQUE_TOKEN=<gerar-forte-com-openssl-rand-hex-32>

# APNs (push + haptic no needs_you/done/error). Todos opcionais: sem eles o
# hub sobe normalmente, só não envia push. Ver docs/11-apns.md.
CUTUQUE_APNS_KEY_PATH=/config/key.p8
CUTUQUE_APNS_KEY_ID=
CUTUQUE_APNS_TEAM_ID=
CUTUQUE_APNS_TOPIC=

# Alvos SSH (Fase 5): "nome=destino,nome2=destino2", onde destino é um alias
# do ~/.ssh/config (montado read-only no container, ver docker-compose.yml) ou
# user@host direto. Vazio: o hub cai no LocalTarget "macbook" (roda o `claude`
# no próprio container/host do hub — normalmente não é o que se quer em
# produção, já que o hub roda no ZimaOS e o agente no MacBook).
# Exemplo real: CUTUQUE_SSH_TARGETS=macbook=user@192.0.2.20,macmini=remote-host
CUTUQUE_SSH_TARGETS=

# Teto de sessões concorrentes vivas (SEC-007). Acima disso, POST /sessions
# responde 429 too_many_sessions.
CUTUQUE_MAX_SESSIONS=20

# Intervalo (segundos) do re-cutucão: de quanto em quanto tempo o hub reenvia
# o push enquanto uma sessão segue em needs_you sem resposta.
CUTUQUE_RENUDGE_SECONDS=15
