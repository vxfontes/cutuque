# Go
/hub/bin/
*.test
*.out

# Segredos — nunca versionar
*.p8
*.pem
*.key
secrets/
.env
.env.*

# macOS / Xcode
.DS_Store
/app/**/xcuserdata/
/app/**/*.xcuserstate
DerivedData/

# Credenciais locais (hub.env, key.p8 etc) — mas os templates *.example
# versionam normalmente (Fase 5, docs/12-deploy-zimaos.md). Precisa ser
# `/config/*` (não `/config/`): excluir o DIRETÓRIO impede git de reconsiderar
# arquivos dentro dele mesmo com "!", só excluir os arquivos permite a
# negação abaixo.
/config/*
!/config/*.example
/app/build/

# Artefato local de tooling (skill copiada), não faz parte do projeto
/skills/
